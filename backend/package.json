{
  "name": "bubbletech-pointage-backend",
  "version": "1.0.0",
  "description": "Backend pour l'application BubbleTech Pointage",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "debug": "DEBUG=bubbletech:* node server.js",
    "debug-dev": "cross-env DEBUG=bubbletech:* nodemon server.js",
    "test": "jest --runInBand",
    "test:brevo-live": "node scripts/testBrevoEmail.js",
    "init-db": "node scripts/initDatabase.js",
    "seed": "node scripts/seedDatabase.js",
    "setup": "node scripts/initDatabase.js && node scripts/seedDatabase.js"
  },
  "keywords": [
    "pointage",
    "gestion",
    "temps"
  ],
  "author": "BubbleTech",
  "license": "ISC",
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.8",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
